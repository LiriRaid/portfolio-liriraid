{
  "name": "portfolio-liriraid",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "pretheme": "tsx --tsconfig tsconfig.tools.json tools/theme/generate-pretheme-index.ts",
    "prelanguage": "tsx --tsconfig tsconfig.tools.json tools/i18n/generate-prelanguage-index.ts",
    "preindex": "pnpm pretheme && pnpm prelanguage",
    "start": "pnpm preindex && ng serve",
    "build": "pnpm preindex && ng build",
    "watch": "pnpm preindex && ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "installsafe": "pnpm install",
    "clisafe": "pnpm ng completion",
    "audit:safe": "pnpm audit --audit-level=moderate",
    "check:deps": "pnpm audit --audit-level=moderate"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-server": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/ssr": "^21.2.15",
    "@emailjs/browser": "^4.4.1",
    "@lucide/angular": "^1.18.0",
    "@primeuix/themes": "^2.0.3",
    "gsap": "^3.15.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@analogjs/vitest-angular": "^2.6.1",
    "@angular/build": "^21.2.15",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "^21.2.17",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
