{
  "name": "portfolio-liriraid",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "pretheme": "tsx --tsconfig tsconfig.tools.json tools/theme/generate-pretheme-index.ts",
    "prelanguage": "tsx --tsconfig tsconfig.tools.json tools/i18n/generate-prelanguage-index.ts",
    "preindex": "pnpm pretheme && pnpm prelanguage",
    "start": "pnpm preindex && ng serve",
    "build": "pnpm preindex && ng build",
    "watch": "pnpm preindex && ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "installsafe": "pnpm install",
    "clisafe": "pnpm ng completion",
    "audit:safe": "pnpm audit --audit-level=moderate",
    "check:deps": "pnpm audit --audit-level=moderate"
  },
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "dependencies": {
    "@angular/cdk": "21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.8",
    "@emailjs/browser": "^4.4.1",
    "@lucide/angular": "^1.14.0",
    "@primeuix/themes": "^2.0.3",
    "gsap": "^3.15.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.19.40",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.8"
  }
}
